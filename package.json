{
  "name": "bible-notes",
  "private": true,
  "version": "1.6.0",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "vite",
    "agent:check": "pnpm run format && pnpm run lint && pnpm run typecheck",
    "codegen": "pnpm exec convex codegen --typecheck disable",
    "build": "vite build",
    "build:vercel": "pnpm exec convex deploy --cmd 'pnpm run build' --cmd-url-env-var-name VITE_CONVEX_URL",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@auth/core": "0.41.1",
    "@convex-dev/auth": "0.0.91",
    "@tanstack/react-router": "1.168.10",
    "@tanstack/router-plugin": "1.167.12",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "convex": "1.34.1",
    "convex-helpers": "0.1.114",
    "fflate": "0.8.2",
    "framer-motion": "12.38.0",
    "html-to-image": "1.11.13",
    "lucide-react": "0.577.0",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "10.1.0",
    "react-resizable-panels": "4.9.0",
    "tailwind-merge": "3.5.0",
    "xlsx": "0.18.5"
